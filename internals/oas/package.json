{
  "name": "@internals/oas",
  "version": "0.0.0",
  "description": "Internal OAS parsing utilities using @scalar/openapi-parser (UNSTABLE).",
  "keywords": [
    "kubb",
    "internal",
    "oas",
    "openapi",
    "scalar",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "internals/oas"
  },
  "license": "MIT",
  "author": "stijnvanhulle",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {}
  },
  "files": [
    "src",
    "dist",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "bun biome lint .",
    "lint:fix": "bun biome lint --fix --unsafe .",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@internals/utils": "workspace:*",
    "@kubb/core": "workspace:*",
    "@scalar/json-magic": "^0.12.1",
    "@scalar/openapi-parser": "^0.25.1",
    "jsonpointer": "^5.0.1",
    "oas": "^28.9.0",
    "openapi-types": "^12.1.3",
    "remeda": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "engines": {
    "node": ">=20"
  }
}
