{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kubb.dev/schemas/extension.json",
  "title": "Kubb Extension Metadata",
  "description": "Unified schema for Kubb extension manifest files (extension.yaml). Covers plugin, adapter, middleware, and parser extension kinds.",
  "type": "object",
  "required": ["kind", "id", "name", "description", "type", "npmPackage"],
  "properties": {
    "kind": {
      "type": "string",
      "description": "Extension kind — what role this package plays in the Kubb pipeline."
    },
    "id": {
      "type": "string",
      "description": "Unique identifier (e.g., 'plugin-react-query', 'adapter-oas').",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name."
    },
    "description": {
      "type": "string",
      "description": "Short description of what the extension does."
    },
    "type": {
      "type": "string",
      "enum": ["official", "community", "3rd-party"],
      "description": "Extension authorship type."
    },
    "npmPackage": {
      "type": "string",
      "description": "NPM package name (e.g., '@kubb/plugin-react-query')."
    },
    "category": {
      "type": "string",
      "description": "Extension category for organisation and filtering."
    },
    "compatibility": {
      "$ref": "#/definitions/compatibility"
    },
    "maintainers": {
      "type": "array",
      "description": "Extension maintainers.",
      "items": { "$ref": "#/definitions/maintainer" }
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "description": "Source repository URL."
    },
    "docsPath": {
      "type": "string",
      "description": "Path to documentation within kubb.dev (e.g., '/plugins/plugin-react-query')."
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "icon": {
      "$ref": "#/definitions/icon"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature this extension prominently."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Discovery tags for search and filtering."
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required Kubb extension dependencies (extension IDs)."
    },
    "options": {
      "type": "array",
      "description": "Configuration options, used to auto-generate reference docs.",
      "items": { "$ref": "#/definitions/extensionOption" }
    },
    "examples": {
      "type": "array",
      "items": { "$ref": "#/definitions/exampleTab" },
      "description": "Page-level ::: code-group rendered as the 'Example' section."
    },
    "intro": {
      "type": "string",
      "description": "Free-form markdown rendered between the header and the Installation section."
    },
    "notes": {
      "type": "array",
      "description": "Page-level callouts rendered after the Installation section.",
      "items": { "$ref": "#/definitions/calloutBlock" }
    }
  },
  "oneOf": [
    {
      "properties": {
        "kind": { "const": "plugin" },
        "category": {
          "enum": ["ai", "client", "documentation", "framework", "mocks", "testing", "types", "validation"]
        }
      },
      "required": ["category"]
    },
    {
      "properties": {
        "kind": { "const": "adapter" },
        "category": {
          "enum": ["asyncapi", "graphql", "grpc", "json", "openapi"]
        }
      },
      "required": ["category"]
    },
    {
      "properties": {
        "kind": { "const": "middleware" }
      }
    },
    {
      "properties": {
        "kind": { "const": "parser" },
        "category": {
          "enum": ["javascript", "json", "typescript", "yaml", "other"]
        }
      },
      "required": ["category"]
    }
  ],
  "definitions": {
    "calloutBlock": {
      "type": "object",
      "required": ["type", "body"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["tip", "note", "important", "warning", "caution"],
          "description": "Callout flavour, mapped to VitePress >[!TYPE] directives."
        },
        "title": { "type": "string", "description": "Optional override for the callout title." },
        "body": { "type": "string", "description": "Markdown body of the callout." }
      }
    },
    "codeBlock": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "lang": { "type": "string", "default": "typescript", "description": "Fence language (e.g. typescript, ts, shell)." },
        "title": { "type": "string", "description": "Optional tab title." },
        "twoslash": { "type": "boolean", "default": false, "description": "When true and lang is typescript/ts, append ` twoslash` to the fence." },
        "code": { "type": "string", "description": "Code body." }
      }
    },
    "exampleFile": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "name": { "type": "string", "description": "Optional file name comment rendered as the first line." },
        "lang": { "type": "string", "default": "typescript" },
        "twoslash": { "type": "boolean", "default": false },
        "code": { "type": "string" }
      }
    },
    "exampleTab": {
      "type": "object",
      "required": ["name", "files"],
      "properties": {
        "name": { "type": "string", "description": "Tab label inside the ::: code-group block." },
        "files": {
          "type": "array",
          "items": { "$ref": "#/definitions/exampleFile" },
          "description": "Multi-file code listing concatenated inside one tab."
        }
      }
    },
    "details": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "codeBlock": { "$ref": "#/definitions/codeBlockOrArray" }
      }
    },
    "badge": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["info", "tip", "warning", "danger"],
          "default": "tip"
        },
        "text": { "type": "string" }
      }
    },
    "extensionOption": {
      "$id": "#extension-option",
      "type": "object",
      "if": { "not": { "required": ["extends"] } },
      "then": { "required": ["name"] },
      "properties": {
        "name": {
          "type": "string",
          "description": "Option name as it appears in the extension config."
        },
        "extends": {
          "type": "string",
          "description": "Relative path to a shared option YAML. Deep-merged under this option; local fields win."
        },
        "type": {
          "type": "string",
          "description": "TypeScript type string shown in the docs table."
        },
        "required": { "type": "boolean", "default": false },
        "default": { "description": "Default value (string representation)." },
        "description": { "type": "string" },
        "badge": {
          "$ref": "#/definitions/badge"
        },
        "experimental": {
          "type": "boolean",
          "default": false
        },
        "typeDefinition": { "type": "string" },
        "codeBlock": { "$ref": "#/definitions/codeBlockOrArray" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/definitions/exampleTab" }
        },
        "tip": { "type": "string" },
        "note": { "type": "string" },
        "important": { "type": "string" },
        "warning": { "type": "string" },
        "details": {
          "type": "array",
          "items": { "$ref": "#/definitions/details" }
        },
        "body": { "type": "string" },
        "deprecated": { "$ref": "#/definitions/deprecated" },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/definitions/extensionOption" },
          "description": "Nested sub-options."
        }
      }
    },
    "compatibility": {
      "type": "object",
      "description": "Version compatibility requirements.",
      "properties": {
        "kubb": { "type": "string", "description": "Kubb version constraint (e.g., '>=5.0.0')" },
        "node": { "type": "string", "description": "Node.js version constraint (e.g., '>=22')" }
      }
    },
    "maintainer": {
      "type": "object",
      "required": ["name", "github"],
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" },
        "avatar": { "type": "string", "format": "uri" }
      }
    },
    "resources": {
      "type": "object",
      "description": "Related resource URLs.",
      "properties": {
        "documentation": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "issues": { "type": "string", "format": "uri" },
        "changelog": { "type": "string", "format": "uri" },
        "codesandbox": { "type": "string", "format": "uri" }
      }
    },
    "codeBlockOrArray": {
      "oneOf": [
        { "$ref": "#/definitions/codeBlock" },
        { "type": "array", "items": { "$ref": "#/definitions/codeBlock" } }
      ]
    },
    "deprecated": {
      "type": "object",
      "description": "Marks an option as deprecated.",
      "properties": {
        "note": { "type": "string", "description": "Migration guidance." }
      }
    },
    "icon": {
      "type": "object",
      "description": "Extension icon URLs.",
      "required": ["light"],
      "properties": {
        "light": { "type": "string", "format": "uri" },
        "dark": { "type": "string", "format": "uri" }
      }
    }
  }
}
