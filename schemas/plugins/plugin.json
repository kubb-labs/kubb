{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kubb.dev/schemas/plugins/plugin.json",
  "title": "Kubb Plugin Metadata",
  "description": "Schema for individual Kubb plugin metadata files",
  "type": "object",
  "required": ["id", "name", "description", "category", "type", "version", "npmPackage"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the plugin (e.g., 'plugin-react-query')",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "description": {
      "type": "string",
      "description": "Short description of what the plugin does"
    },
    "category": {
      "type": "string",
      "enum": ["specification", "framework", "testing", "utility", "documentation", "ai"],
      "description": "Plugin category for organization"
    },
    "type": {
      "type": "string",
      "enum": ["official", "community", "3rd-party"],
      "description": "Plugin authorship type"
    },
    "version": {
      "type": "string",
      "description": "Current semantic version",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.]+)?$"
    },
    "npmPackage": {
      "type": "string",
      "description": "NPM package name (e.g., '@kubb/plugin-react-query')"
    },
    "compatibility": {
      "type": "object",
      "description": "Version compatibility requirements",
      "properties": {
        "kubb": {
          "type": "string",
          "description": "Kubb version constraint (e.g., '>=5.0.0')"
        },
        "node": {
          "type": "string",
          "description": "Node.js version constraint (e.g., '>=18.0.0')"
        }
      }
    },
    "maintainers": {
      "type": "array",
      "description": "Plugin maintainers",
      "items": {
        "type": "object",
        "required": ["name", "github"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Maintainer's display name"
          },
          "github": {
            "type": "string",
            "description": "GitHub username"
          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "description": "Avatar image URL"
          }
        }
      }
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "description": "Source repository URL"
    },
    "docsPath": {
      "type": "string",
      "description": "Path to documentation within kubb.dev (e.g., '/plugins/plugin-react-query')"
    },
    "resources": {
      "type": "object",
      "description": "Related resource URLs",
      "properties": {
        "documentation": {
          "type": "string",
          "format": "uri",
          "description": "Documentation URL"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Repository URL"
        },
        "issues": {
          "type": "string",
          "format": "uri",
          "description": "Issue tracker URL"
        },
        "changelog": {
          "type": "string",
          "format": "uri",
          "description": "Changelog URL"
        }
      }
    },
    "icon": {
      "type": "string",
      "description": "Emoji or icon identifier for display"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature this plugin prominently"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Discovery tags for search and filtering"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required Kubb plugin dependencies (plugin IDs)"
    },
    "skills": {
      "type": "array",
      "description": "Plugin capabilities exposed to AI tools",
      "items": {
        "$ref": "#/definitions/skill"
      }
    }
  },
  "definitions": {
    "skill": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Skill identifier (e.g., 'generate-react-query-hooks')",
          "pattern": "^[a-z0-9-]+$"
        },
        "description": {
          "type": "string",
          "description": "What this skill does"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for skill categorization"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required packages or plugins"
        },
        "apiParameters": {
          "type": "array",
          "description": "Configuration parameters for this skill",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Parameter name"
              },
              "type": {
                "type": "string",
                "description": "Parameter type"
              },
              "required": {
                "type": "boolean",
                "default": false,
                "description": "Whether the parameter is required"
              },
              "default": {
                "description": "Default value"
              },
              "description": {
                "type": "string",
                "description": "Parameter description"
              }
            }
          }
        },
        "examples": {
          "type": "array",
          "description": "Usage examples",
          "items": {
            "type": "object",
            "required": ["title", "code"],
            "properties": {
              "title": {
                "type": "string",
                "description": "Example title"
              },
              "description": {
                "type": "string",
                "description": "Example description"
              },
              "code": {
                "type": "string",
                "description": "Code snippet"
              },
              "output": {
                "type": "string",
                "description": "Expected output"
              }
            }
          }
        }
      }
    }
  }
}
