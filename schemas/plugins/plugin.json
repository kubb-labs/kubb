{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kubb.dev/schemas/plugin.json",
  "title": "Kubb Plugin Metadata",
  "description": "Schema for individual Kubb plugin metadata files",
  "type": "object",
  "required": ["id", "name", "description", "category", "type", "version", "npmPackage"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the plugin (e.g., 'plugin-react-query')",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name"
    },
    "description": {
      "type": "string",
      "description": "Short description of what the plugin does"
    },
    "category": {
      "type": "string",
      "enum": ["types", "client", "validation", "framework", "mocks", "testing", "documentation", "ai"],
      "description": "Plugin category for organization"
    },
    "type": {
      "type": "string",
      "enum": ["official", "community", "sponsor", "3rd-party"],
      "description": "Plugin authorship type"
    },
    "version": {
      "type": "string",
      "description": "Current semantic version",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.]+)?$"
    },
    "npmPackage": {
      "type": "string",
      "description": "NPM package name (e.g., '@kubb/plugin-react-query')"
    },
    "compatibility": {
      "type": "object",
      "description": "Version compatibility requirements",
      "properties": {
        "kubb": {
          "type": "string",
          "description": "Kubb version constraint (e.g., '>=5.0.0')"
        },
        "node": {
          "type": "string",
          "description": "Node.js version constraint (e.g., '>=18.0.0')"
        }
      }
    },
    "maintainers": {
      "type": "array",
      "description": "Plugin maintainers",
      "items": {
        "type": "object",
        "required": ["name", "github"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Maintainer's display name"
          },
          "github": {
            "type": "string",
            "description": "GitHub username"
          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "description": "Avatar image URL"
          }
        }
      }
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "description": "Source repository URL"
    },
    "docsPath": {
      "type": "string",
      "description": "Path to documentation within kubb.dev (e.g., '/plugins/plugin-react-query')"
    },
    "resources": {
      "type": "object",
      "description": "Related resource URLs",
      "properties": {
        "documentation": {
          "type": "string",
          "format": "uri",
          "description": "Documentation URL"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Repository URL"
        },
        "issues": {
          "type": "string",
          "format": "uri",
          "description": "Issue tracker URL"
        },
        "changelog": {
          "type": "string",
          "format": "uri",
          "description": "Changelog URL"
        }
      }
    },
    "iconLight": {
      "type": "string",
      "format": "uri",
      "description": "URL to the plugin icon for light mode (e.g. https://kubb.dev/feature/typescript.svg)"
    },
    "iconDark": {
      "type": "string",
      "format": "uri",
      "description": "URL to the plugin icon for dark mode. Falls back to iconLight when omitted."
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature this plugin prominently"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Discovery tags for search and filtering"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required Kubb plugin dependencies (plugin IDs)"
    },
    "skills": {
      "type": "array",
      "description": "Plugin capabilities exposed to AI tools",
      "items": {
        "$ref": "#/definitions/skill"
      }
    },
    "options": {
      "type": "array",
      "description": "Plugin configuration options, used to auto-generate reference docs.",
      "items": {
        "$ref": "#/definitions/pluginOption"
      }
    },
    "fullExample": {
      "type": "string",
      "description": "A complete kubb.config.ts snippet (defineConfig + all plugins) used as the Example section on the generated reference page."
    },
    "stats": {
      "type": "object",
      "description": "Live statistics injected at build time by generatePlugins.ts — not present in source YAML files.",
      "properties": {
        "downloads": {
          "type": "integer",
          "minimum": 0,
          "description": "npm downloads in the last calendar month"
        },
        "stars": {
          "type": "integer",
          "minimum": 0,
          "description": "GitHub star count for the plugin's source repository"
        },
        "bundleSize": {
          "type": "integer",
          "minimum": 0,
          "description": "Unpacked tarball size of the latest published version, in bytes (from the npm registry)."
        }
      },
      "required": ["downloads", "stars"],
      "additionalProperties": false
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "Publish time of the latest version on npm, as a UTC ISO 8601 string. Injected at build time by generatePlugins.ts — not present in source YAML files."
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Publish time of the first version on npm, as a UTC ISO 8601 string. Injected at build time by generatePlugins.ts — not present in source YAML files."
    }
  },
  "definitions": {
    "pluginOption": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Option name as it appears in the plugin config (e.g. 'output', 'infinite')."
        },
        "type": {
          "type": "string",
          "description": "TypeScript type string shown in the docs table (e.g. 'string', 'boolean', 'Infinite | false')."
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "description": "Default value. Use a string representation (e.g. \"'hooks'\", \"false\", \"0\")."
        },
        "description": {
          "type": "string"
        },
        "typeDefinition": {
          "type": "string",
          "description": "Multiline TypeScript type block, rendered in a fenced typescript code block."
        },
        "example": {
          "type": "string",
          "description": "Short TypeScript usage snippet, rendered in a fenced typescript code block."
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "deprecationNote": {
          "type": "string",
          "description": "Migration guidance. Only shown when deprecated is true."
        },
        "tip": {
          "type": "string",
          "description": "Optional callout rendered as a > [!TIP] block directly under the option's metadata table."
        },
        "values": {
          "type": "array",
          "description": "Per-value metadata for union-typed options. Each entry documents one possible literal value.",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "The literal value string, e.g. \"'object'\" or \"'inline'\"."
              },
              "description": {
                "type": "string",
                "description": "What this specific value does."
              },
              "example": {
                "type": "string",
                "description": "TypeScript code snippet showing generated output when this value is active."
              }
            }
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/pluginOption"
          },
          "description": "Nested sub-options (e.g. output.path, output.barrelType)."
        }
      }
    },
    "skill": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Skill identifier (e.g., 'generate-react-query-hooks')",
          "pattern": "^[a-z0-9-]+$"
        },
        "description": {
          "type": "string",
          "description": "What this skill does"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for skill categorization"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required packages or plugins"
        },
        "apiParameters": {
          "type": "array",
          "description": "Configuration parameters for this skill",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Parameter name"
              },
              "type": {
                "type": "string",
                "description": "Parameter type"
              },
              "required": {
                "type": "boolean",
                "default": false,
                "description": "Whether the parameter is required"
              },
              "default": {
                "description": "Default value"
              },
              "description": {
                "type": "string",
                "description": "Parameter description"
              }
            }
          }
        },
        "examples": {
          "type": "array",
          "description": "Usage examples",
          "items": {
            "type": "object",
            "required": ["title", "code"],
            "properties": {
              "title": {
                "type": "string",
                "description": "Example title"
              },
              "description": {
                "type": "string",
                "description": "Example description"
              },
              "code": {
                "type": "string",
                "description": "Code snippet"
              },
              "output": {
                "type": "string",
                "description": "Expected output"
              }
            }
          }
        }
      }
    }
  }
}
