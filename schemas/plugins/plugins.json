{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kubb.dev/schemas/plugins/plugins.json",
  "title": "Kubb Plugin Registry",
  "description": "Schema for the aggregated Kubb plugin registry",
  "type": "object",
  "required": ["$schema", "version", "plugins"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Registry schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "plugins": {
      "type": "array",
      "description": "Array of plugin metadata",
      "items": {
        "$ref": "https://kubb.dev/schemas/plugins/plugin.json"
      }
    },
    "categories": {
      "type": "array",
      "description": "Available plugin categories with metadata",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Category identifier"
          },
          "name": {
            "type": "string",
            "description": "Category display name"
          },
          "description": {
            "type": "string",
            "description": "Category description"
          },
          "icon": {
            "type": "string",
            "description": "Category icon"
          }
        }
      }
    },
    "skillsIndex": {
      "type": "array",
      "description": "Index of all available skills across plugins",
      "items": {
        "type": "object",
        "required": ["name", "pluginId"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Skill name"
          },
          "pluginId": {
            "type": "string",
            "description": "Parent plugin ID"
          },
          "description": {
            "type": "string",
            "description": "Skill description"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
