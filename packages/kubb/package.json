{
  "name": "kubb",
  "version": "5.0.0-beta.36",
  "description": "Meta-package and entry point for Kubb — a plugin-based code generation framework for OpenAPI. Includes defineConfig, all public APIs, and serves as the gateway to the entire Kubb ecosystem.",
  "keywords": [
    "api-client",
    "code-generator",
    "codegen",
    "faker",
    "kubb",
    "meta-framework",
    "msw",
    "openapi",
    "plugin-system",
    "react-query",
    "sdk-generator",
    "swagger",
    "tanstack-query",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/kubb"
  },
  "bin": {
    "kubb": "bin/kubb.js"
  },
  "files": [
    "src",
    "dist",
    "bin",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "workspace:*",
    "@kubb/cli": "workspace:*",
    "@kubb/core": "workspace:*",
    "@kubb/mcp": "workspace:*",
    "@kubb/middleware-barrel": "workspace:*",
    "@kubb/parser-md": "workspace:*",
    "@kubb/parser-ts": "workspace:*",
    "@kubb/renderer-jsx": "workspace:*"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@kubb/agent": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@kubb/agent": {
      "optional": true
    }
  },
  "size-limit": [
    {
      "path": "./dist/*.js",
      "limit": "510 KiB",
      "gzip": true
    }
  ],
  "preferGlobal": true,
  "engines": {
    "node": ">=22"
  }
}
