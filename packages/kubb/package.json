{
  "name": "kubb",
  "version": "5.0.0-beta.77",
  "description": "The meta framework for code generation. Point Kubb at a schema and it generates types, clients, hooks, validators, mocks, and more.",
  "keywords": [
    "api-client",
    "code-generator",
    "codegen",
    "faker",
    "kubb",
    "meta-framework",
    "msw",
    "plugin-system",
    "sdk-generator",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/kubb"
  },
  "bin": {
    "kubb": "bin/kubb.js"
  },
  "files": [
    "dist",
    "bin",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"require('node:fs').rmSync('./dist', {recursive:true,force:true})\"",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "release:stage": "pnpm stage publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "workspace:*",
    "@kubb/cli": "workspace:*",
    "@kubb/core": "workspace:*",
    "@kubb/mcp": "workspace:*",
    "@kubb/parser-md": "workspace:*",
    "@kubb/parser-ts": "workspace:*",
    "@kubb/plugin-barrel": "workspace:*",
    "@kubb/renderer-jsx": "workspace:*"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*",
    "typescript": "catalog:"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=22"
  }
}
