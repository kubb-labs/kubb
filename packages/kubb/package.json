{
  "name": "kubb",
  "version": "5.0.0-alpha.48",
  "description": "Transform OpenAPI specifications into TypeScript, React-Query, Zod, Faker.js, MSW and more with a plugin-based code generation tool.",
  "keywords": [
    "api-client",
    "cli",
    "code-generator",
    "codegen",
    "faker",
    "kubb",
    "msw",
    "oas",
    "openapi",
    "plugin-system",
    "plugins",
    "react-query",
    "sdk-generator",
    "swagger",
    "tanstack-query",
    "type-safe",
    "typescript",
    "zod"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/kubb"
  },
  "bin": {
    "kubb": "bin/kubb.js"
  },
  "files": [
    "src",
    "dist",
    "bin",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "workspace:*",
    "@kubb/agent": "workspace:*",
    "@kubb/cli": "workspace:*",
    "@kubb/core": "workspace:*",
    "@kubb/mcp": "workspace:*",
    "@kubb/parser-ts": "workspace:*"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*"
  },
  "size-limit": [
    {
      "path": "./dist/*.js",
      "limit": "510 KiB",
      "gzip": true
    }
  ],
  "preferGlobal": true,
  "engines": {
    "node": ">=22"
  }
}
