{
  "name": "@kubb/middleware-barrel",
  "version": "5.0.0-beta.27",
  "description": "Barrel-file middleware for Kubb. Automatically generates index.ts re-export files per plugin output directory and an optional root barrel after all plugins complete.",
  "keywords": [
    "barrel",
    "codegen",
    "kubb",
    "middleware",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/middleware-barrel"
  },
  "files": [
    "src",
    "dist",
    "extension.yaml",
    "*.d.ts",
    "*.d.cts",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/ast": "workspace:*"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*"
  },
  "peerDependencies": {
    "@kubb/core": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
