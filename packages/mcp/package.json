{
  "name": "@kubb/mcp",
  "version": "5.0.0-beta.42",
  "description": "MCP server for Kubb. Exposes code generation as a tool over the Model Context Protocol so AI assistants like Claude, Cursor, and other MCP-compatible clients can generate TypeScript types, clients, and more from OpenAPI specs.",
  "keywords": [
    "ai",
    "codegen",
    "kubb",
    "llm",
    "mcp",
    "model-context-protocol",
    "openapi",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/mcp"
  },
  "bin": {
    "kubb-mcp": "bin/kubb-mcp.cjs"
  },
  "files": [
    "src",
    "dist",
    "bin",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"require('node:fs').rmSync('./dist', {recursive:true,force:true})\"",
    "debug:mcp": "npx -y @modelcontextprotocol/inspector node ./bin/kubb-mcp.cjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "release:stage": "pnpm stage publish --no-git-check",
    "start": "tsdown --watch",
    "start:mcp": "bun --watch ./src/server.ts",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "workspace:*",
    "@kubb/core": "workspace:*",
    "@remix-run/node-fetch-server": "^0.13.3",
    "@tmcp/adapter-valibot": "^0.1.6",
    "@tmcp/transport-http": "^0.8.6",
    "@tmcp/transport-stdio": "^0.4.3",
    "jiti": "^2.7.0",
    "tmcp": "^1.19.4",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@internals/shared": "workspace:*",
    "@internals/utils": "workspace:*",
    "@kubb/renderer-jsx": "workspace:*"
  },
  "peerDependencies": {
    "@kubb/renderer-jsx": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
