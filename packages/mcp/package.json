{
  "name": "@kubb/mcp",
  "version": "5.0.0-beta.104",
  "description": "MCP server for Kubb. Exposes code generation as a tool over the Model Context Protocol so AI assistants like Claude, Cursor, and other MCP-compatible clients can generate TypeScript types, clients, and more.",
  "keywords": [
    "ai",
    "codegen",
    "kubb",
    "llm",
    "mcp",
    "meta-framework",
    "model-context-protocol",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/mcp"
  },
  "bin": {
    "kubb-mcp": "bin/kubb-mcp.cjs"
  },
  "files": [
    "dist",
    "bin",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"require('node:fs').rmSync('./dist', {recursive:true,force:true})\"",
    "debug:mcp": "npx -y @modelcontextprotocol/inspector node ./bin/kubb-mcp.cjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "start": "tsdown --watch",
    "start:mcp": "bun --watch ./src/server.ts",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/adapter-oas": "workspace:*",
    "@kubb/core": "workspace:*",
    "@tmcp/adapter-valibot": "^0.1.6",
    "@tmcp/transport-stdio": "^0.4.3",
    "tmcp": "^1.19.4",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@internals/shared": "workspace:*",
    "@internals/utils": "workspace:*",
    "@kubb/renderer-jsx": "workspace:*"
  },
  "peerDependencies": {
    "@kubb/renderer-jsx": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
