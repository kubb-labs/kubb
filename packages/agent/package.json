{
  "name": "@kubb/agent",
  "version": "5.0.0-beta.42",
  "description": "HTTP agent server for Kubb. Exposes code generation via REST API and WebSocket with real-time Kubb Studio integration, machine binding, and Docker support.",
  "keywords": [
    "agent",
    "codegen",
    "docker",
    "http",
    "kubb",
    "openapi",
    "server",
    "typescript",
    "websocket"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/agent"
  },
  "files": [
    ".output",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "nitro build",
    "clean": "npx rimraf ./dist .output",
    "dev": "nitro dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "nitro prepare",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "release:stage": "pnpm stage publish --no-git-check",
    "start": "node .output/server/index.mjs",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/ast": "workspace:*",
    "@kubb/core": "workspace:*",
    "@logtail/node": "^0.5.8",
    "consola": "^3.4.2",
    "jiti": "^2.7.0",
    "remeda": "catalog:",
    "tinyexec": "catalog:",
    "unstorage": "^1.17.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*",
    "@kubb/adapter-oas": "workspace:*",
    "@kubb/parser-ts": "workspace:*",
    "@kubb/renderer-jsx": "workspace:*",
    "@types/ws": "^8.18.1",
    "msw": "^2.14.6",
    "nitropack": "^2.13.4",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22"
  }
}
