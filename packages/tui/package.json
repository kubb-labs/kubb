{
  "name": "@kubb/tui",
  "version": "5.0.0-beta.36",
  "description": "Full-screen terminal UI for Kubb generation. Live plugin progress, file-write progress, and a scrollable log pane, rendered with opentui and React. Opt-in via the CLI `--tui` flag.",
  "keywords": [
    "cli",
    "codegen",
    "kubb",
    "openapi",
    "opentui",
    "react",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/tui"
  },
  "files": [
    "src",
    "dist",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "release:stage": "pnpm stage publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/core": "workspace:*",
    "@opentui/core": "^0.1.0",
    "@opentui/react": "^0.1.0",
    "react": "catalog:"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*",
    "@types/react": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.1"
  }
}
