{
  "name": "@kubb/adapter-oas",
  "version": "5.0.0-alpha.48",
  "description": "OpenAPI / Swagger adapter for Kubb converts OAS input into a @kubb/ast RootNode.",
  "keywords": [
    "adapter",
    "codegen",
    "kubb",
    "oas",
    "openapi",
    "swagger",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/adapter-oas"
  },
  "files": [
    "src",
    "dist",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/core": "workspace:*",
    "@redocly/openapi-core": "^2.28.1",
    "oas": "^32.1.14",
    "oas-normalize": "^16.0.4",
    "swagger2openapi": "^7.0.8"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*",
    "@types/swagger2openapi": "^7.0.4",
    "openapi-types": "^12.1.3"
  },
  "engines": {
    "node": ">=22"
  },
  "inlinedDependencies": {
    "openapi-types": "12.1.3"
  }
}
