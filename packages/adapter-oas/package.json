{
  "name": "@kubb/adapter-oas",
  "version": "4.36.1",
  "description": "OpenAPI / Swagger adapter for Kubb — converts OAS input into a @kubb/ast RootNode.",
  "keywords": [
    "openapi",
    "swagger",
    "oas",
    "adapter",
    "kubb",
    "codegen",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/adapter-oas"
  },
  "license": "MIT",
  "author": "stijnvanhulle",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "npx rimraf ./dist",
    "lint": "bun biome lint .",
    "lint:fix": "bun biome lint --fix --unsafe .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check",
    "start": "tsdown --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/ast": "workspace:*",
    "@kubb/core": "workspace:*",
    "@kubb/fabric-core": "catalog:",
    "@redocly/openapi-core": "^2.24.1",
    "@stoplight/yaml": "^4.3.0",
    "fflate": "^0.8.2",
    "jsonpointer": "^5.0.1",
    "oas": "^31.1.2",
    "oas-normalize": "^16.0.2",
    "openapi-types": "^12.1.3",
    "remeda": "catalog:",
    "swagger2openapi": "^7.0.8"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*",
    "@types/swagger2openapi": "^7.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js"
}
