{
  "name": "@kubb/renderer-jsx",
  "version": "5.0.0-beta.49",
  "description": "Self-contained synchronous JSX renderer for Kubb. Turns JSX into FileNodes with built-in components (File, Function, Type, Const) for component-based, type-safe code generation. No React dependency.",
  "keywords": [
    "codegen",
    "jsx",
    "jsx-runtime",
    "kubb",
    "typescript"
  ],
  "license": "MIT",
  "author": "stijnvanhulle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubb-labs/kubb.git",
    "directory": "packages/renderer-jsx"
  },
  "files": [
    "src",
    "dist",
    "*.d.ts",
    "*.d.cts",
    "!*.map",
    "!/**/**.test.**",
    "!/**/__tests__/**",
    "!/**/__snapshots__/**"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/globals.js",
    "./dist/globals.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "globals": [
        "./dist/globals.d.ts"
      ],
      "jsx-dev-runtime": [
        "./dist/jsx-runtime.d.ts"
      ],
      "jsx-runtime": [
        "./dist/jsx-runtime.d.ts"
      ],
      "types": [
        "./dist/types.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/jsx-dev-runtime.js",
      "require": "./dist/jsx-dev-runtime.cjs"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "node -e \"require('fs').rmSync('./dist', {recursive:true,force:true})\"",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "release": "pnpm publish --no-git-check",
    "release:canary": "bash ../../.github/canary.sh && node ../../scripts/build.js canary && pnpm publish --no-git-check -tag canary",
    "release:stage": "pnpm stage publish --no-git-check",
    "start": "tsdown --watch ./src",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc -p ./tsconfig.json --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@kubb/ast": "workspace:*",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@internals/utils": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
