{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./configs/bundler.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["bun-types"],
    "paths": {
      "#mocks": ["./internals/utils/src/mocks.ts"],
      "@kubb/core/mocks": ["./packages/core/src/mocks.ts"],
      "@internals/utils": ["./internals/utils/src/index.ts"],
      "@internals/shared": ["./internals/shared/src/index.ts"],
      "@kubb/ast": ["./packages/ast/src/index.ts"],
      "@kubb/core": ["./packages/core/src/index.ts"],
      "@kubb/mcp": ["./packages/mcp/src/index.ts"],
      "@kubb/renderer-jsx": ["./packages/renderer-jsx/src/index.ts"],
      "@kubb/renderer-jsx/jsx-runtime": ["./packages/renderer-jsx/src/jsx-runtime.ts"],
      "@kubb/renderer-jsx/jsx-dev-runtime": ["./packages/renderer-jsx/src/jsx-runtime.ts"],
      "@kubb/parser-ts": ["./packages/parser-ts/src/index.ts"],
      "@kubb/adapter-oas": ["./packages/adapter-oas/src/index.ts"],
      "@kubb/parser-md": ["./packages/parser-md/src/index.ts"],
      "unplugin-kubb": ["./packages/unplugin/src/index.ts"],
      "@kubb/middleware-barrel": ["./packages/middleware-barrel/src/index.ts"],
      "@kubb/plugin-barrel": ["./packages/plugin-barrel/src/index.ts"]
    }
  },
  "include": ["./package.json", "./tsdown.config.ts", "./vitest.config.ts", "./src/**/*", "tests"],
  "exclude": ["node_modules", "dist", "tmp", "coverage", "**/__snapshots__/**"]
}
